		local _vector3_1 = Vector3.new(0, 0, -1)
		v = _v + _vector3_1
	end
	if keys.s then
		local _v = v
		local _vector3_1 = Vector3.new(0, 0, 1)
		v = _v + _vector3_1
	end
	if keys.a then
		local _v = v
		local _vector3_1 = Vector3.new(-1, 0, 0)
		v = _v + _vector3_1
	end
	if keys.d then
		local _v = v
		local _vector3_1 = Vector3.new(1, 0, 0)
