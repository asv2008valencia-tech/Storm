function charFromPart(part)
	local _m = part
	if _m ~= nil then
		_m = _m.Parent
	end
	local m = _m
	if not m then
		return nil
	end
	if m:IsA("Accessory") then
		m = m.Parent
	end
	if m and m:FindFirstChildOfClass("Humanoid") then
